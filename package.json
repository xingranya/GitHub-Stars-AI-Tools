{
  "name": "github-stars-ai-tools",
  "version": "1.5.3",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/xingranya/GitHub-Stars-AI-Tools",
  "repository": {
    "type": "git",
    "url": "https://github.com/xingranya/GitHub-Stars-AI-Tools.git"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "pnpm --filter @gsat/desktop dev",
    "build": "pnpm build:packages && pnpm --filter @gsat/desktop build",
    "build:packages": "tsc -b tsconfig.packages.json",
    "package:desktop": "pnpm build:packages && pnpm --filter @gsat/desktop tauri build",
    "package:desktop:dmg": "pnpm build:packages && pnpm --filter @gsat/desktop package:dmg:macos",
    "tauri": "pnpm --filter @gsat/desktop tauri"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  }
}
