{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitHub-Stars-AI-Tools",
  "version": "1.5.3",
  "identifier": "com.xingranya.github-stars-ai-tools",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && node scripts/prepare-native-runtime.mjs --bootstrap",
    "beforeBundleCommand": "node scripts/prepare-native-runtime.mjs",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GitHub-Stars-AI-Tools",
        "width": 1280,
        "height": 820,
        "minWidth": 720,
        "minHeight": 560,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:1420 ws://127.0.0.1:1420; img-src 'self' https: data: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; script-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "dmg": {
        "windowSize": {
          "width": 900,
          "height": 560
        },
        "appPosition": {
          "x": 300,
          "y": 285
        },
        "applicationFolderPosition": {
          "x": 620,
          "y": 285
        }
      }
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU2NTREMjlCM0Q2MkYxOTMKUldTVDhXSTltOUpVNXBlT0x2WDNDa2h3VGlVeGMrMHdLWk85QnZpNFB2aVozY3BpSEt5dnNsMy8K",
      "endpoints": [
        "https://github.com/xingranya/GitHub-Stars-AI-Tools/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
