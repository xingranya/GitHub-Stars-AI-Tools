{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitHub-Stars-AI-Tools",
  "version": "0.1.0",
  "identifier": "com.xingranya.github-stars-ai-tools",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GitHub-Stars-AI-Tools",
        "width": 1280,
        "height": 820,
        "minWidth": 720,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
